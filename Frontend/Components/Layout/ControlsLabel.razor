@rendermode InteractiveServer
@inject API api
<div class="controls-label">
    <div class="user-icon">@api.GetCurrentUser()!.UserName.Substring(0, 1).ToUpper()</div>
    <svg xmlns="http://www.w3.org/2000/svg" class="settings-icon" @onclick="ToggleSettings" viewBox="0 0 24 24"><path fill="currentColor" d="m9.25 22l-.4-3.2q-.325-.125-.612-.3t-.563-.375L4.7 19.375l-2.75-4.75l2.575-1.95Q4.5 12.5 4.5 12.338v-.675q0-.163.025-.338L1.95 9.375l2.75-4.75l2.975 1.25q.275-.2.575-.375t.6-.3l.4-3.2h5.5l.4 3.2q.325.125.613.3t.562.375l2.975-1.25l2.75 4.75l-2.575 1.95q.025.175.025.338v.674q0 .163-.05.338l2.575 1.95l-2.75 4.75l-2.95-1.25q-.275.2-.575.375t-.6.3l-.4 3.2zm2.8-6.5q1.45 0 2.475-1.025T15.55 12t-1.025-2.475T12.05 8.5q-1.475 0-2.488 1.025T8.55 12t1.013 2.475T12.05 15.5"/></svg>
</div>


@if (_displayCategory != "")
{
    <div class="settings-menu">
        <div class="settings-sidebar">
            <div class="settings-category" @onclick="DisplayUser">
                <svg xmlns="http://www.w3.org/2000/svg" class="settings-category-icon" viewBox="0 0 24 24"><path fill="currentColor" d="M12 4a4 4 0 0 1 4 4a4 4 0 0 1-4 4a4 4 0 0 1-4-4a4 4 0 0 1 4-4m0 10c4.42 0 8 1.79 8 4v2H4v-2c0-2.21 3.58-4 8-4"/></svg>
                User settings
            </div>
            @if (api.GetCurrentUser()!.UserName == "admin")
            {
                <div class="settings-category" @onclick="DisplayAdmin">
                    <svg xmlns="http://www.w3.org/2000/svg" class="settings-category-icon" viewBox="0 0 512 512"><path fill="currentColor" d="m294.28 256.9l-54.42-54.41a12 12 0 0 0-17 0L12.45 401a12 12 0 0 0-.27 17.2l66.05 66.28a12 12 0 0 0 17.22-.23l198.81-210.36a12 12 0 0 0 .02-16.99m205.05-57.57l-43.89-43.58a21.46 21.46 0 0 0-15.28-6.26a21.9 21.9 0 0 0-12.79 4.14c0-.43.06-.85.09-1.22c.45-6.5 1.15-16.32-5.2-25.22a258 258 0 0 0-24.8-28.74a.6.6 0 0 0-.08-.08c-13.32-13.12-42.31-37.83-86.72-55.94A139.6 139.6 0 0 0 257.56 32C226 32 202 46.24 192.81 54.68A53.4 53.4 0 0 0 176 86.17L192 96s8.06-2 13.86-3.39a62.7 62.7 0 0 1 18.45-1.15c13.19 1.09 28.79 7.64 35.69 13.09c11.7 9.41 17.33 22.09 18.26 41.09c.2 4.23-9.52 21.35-24.16 39.84a8 8 0 0 0 .61 10.62l45.37 45.37a8 8 0 0 0 11 .25c12.07-11 30.49-28 34.67-30.59c7.69-4.73 13.19-5.64 14.7-5.8a19.2 19.2 0 0 1 11.29 2.38a1.24 1.24 0 0 1-.31.95l-1.82 1.73l-.3.28a21.52 21.52 0 0 0 .05 30.54l43.95 43.68a8 8 0 0 0 11.28 0l74.68-74.2a8 8 0 0 0 .06-11.36"/></svg>
                    Admin
                </div>
            }
        </div>
        <div class="settings-content">
            @if (_displayCategory == "User")
            {
                <div>
                    <h2 style="color: white; margin-top: 10px; margin-left: 10px;">Change password</h2>
                    <div class="text-label">Old password:</div>
                    <input type="password" class="text-field" @bind="_oldPassword" @bind:event="oninput"/>
                    <div class="text-label">New password:</div>
                    <input type="password" class="text-field" @bind="_newPassword" @bind:event="oninput"/>
                    <div>
                        <button class="button" @onclick="ChangePasswordAsync">@_changePasswordButtonText</button>
                    </div>
                </div>
            }else if (_displayCategory == "Admin")
            {
                <div>
                    <h2 style="color: white; margin-top: 10px; margin-left: 10px;">Create user</h2>
                    <div class="text-label">Username</div>
                    <input type="password" class="text-field" @bind="_newUserUsername" @bind:event="oninput"/>
                    <div class="text-label">Password:</div>
                    <input type="password" class="text-field" @bind="_newUserPassword" @bind:event="oninput"/>
                    <div>
                        <button class="button" @onclick="CreateUserAsync">@_createUserButtonText</button>
                    </div>
                </div>
            }
        </div>
    </div> 
}

@code {
    private string _displayCategory = "";
    private string _oldPassword = "";
    private string _newPassword = "";
    private string _changePasswordButtonText = "Change password";
    private string _newUserUsername = "";
    private string _newUserPassword = "";
    private string _createUserButtonText = "Create user";

    private void ToggleSettings()
    {
        _displayCategory = _displayCategory == "" ? "User" : "";
    }
    
    private void DisplayUser()
    {
        _displayCategory = "User";
    }

    private void DisplayAdmin()
    {
        _displayCategory = "Admin";
    }

    private async Task CreateUserAsync()
    {
        await api.CreateUserAsync(_newUserUsername, _newUserPassword);
        _newUserUsername = "";
        _newUserPassword = "";
        await InvokeAsync(StateHasChanged);
    }

    private async Task ChangePasswordAsync()
    {
        Console.WriteLine("Change password button");
        bool success = await api.ChangePasswordAsync(_oldPassword, _newPassword);
        Console.WriteLine($"Success: {success}");
        _changePasswordButtonText = success ? "Success!" : "Error!";
        Console.WriteLine(_changePasswordButtonText);
        await InvokeAsync(StateHasChanged);
        await Task.Delay(2000).ContinueWith(async task =>
        {
            _changePasswordButtonText = "Change password";
            await InvokeAsync(StateHasChanged);
        });
    }
}